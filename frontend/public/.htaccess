<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect /sitemap to /sitemap.xml
  RewriteRule ^sitemap$ /sitemap.xml [R=301,L]

  # SPA Routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
